certificate:
  name: root-ca
  secretName: root-ca-secret
  issuerName: root-ca-issuer
  rootDomain: {{ .Environment.Values.rootDomain }}
  rootCommonName: Quack Cluster Root CA
  subject:
    organizations:
      - "Quack Cluster"
    organizationalUnits:
      - "Quackerspace"
    countries:
      - "PL"
    provinces:
      - "Silesia"
    localities:
      - "Warsaw"
